APP_NAME=ETF Systematic Portfolio Platform
APP_ENV=production
DOMAIN=etf.example.com
ACME_EMAIL=admin@example.com

POSTGRES_DB=quant_etf
POSTGRES_USER=quant_etf
POSTGRES_PASSWORD=replace-with-a-long-random-password

TUSHARE_TOKEN=
TUSHARE_API_URL=https://api.tushare.pro
TUSHARE_REQUEST_INTERVAL_SECONDS=1.5
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=45
DEEPSEEK_MAX_TOKENS=1800
DEEPSEEK_THINKING_ENABLED=false
WORKFLOW_EXECUTION_MODE=worker
WORKFLOW_WORKER_POLL_SECONDS=2
WORKFLOW_WORKER_HEARTBEAT_TTL_SECONDS=30
DAILY_MAINTENANCE_ENABLED=false
DAILY_MAINTENANCE_TIME=18:30
DAILY_MAINTENANCE_SCOPE=enabled
DAILY_MAINTENANCE_LOOKBACK_DAYS=10
DAILY_MAINTENANCE_MAX_SYMBOLS=120
DAILY_MAINTENANCE_REQUEST_INTERVAL_SECONDS=1.5
DAILY_MAINTENANCE_STRATEGY_CODE=core_etf_rotation
DAILY_MAINTENANCE_PORTFOLIO_VALUE=100000
DAILY_MAINTENANCE_GENERATE_REPORT=true

AUTH_ENABLED=true
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD_HASH='replace-with-generate-auth-secrets-output'
AUTH_SESSION_SECRET='replace-with-generate-auth-secrets-output'
AUTH_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=true
