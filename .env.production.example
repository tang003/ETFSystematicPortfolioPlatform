APP_NAME=ETF Systematic Portfolio Platform
APP_ENV=production
DOMAIN=etf.example.com
ACME_EMAIL=admin@example.com

POSTGRES_DB=quant_etf
POSTGRES_USER=quant_etf
POSTGRES_PASSWORD=replace-with-a-long-random-password

TUSHARE_TOKEN=
TUSHARE_REQUEST_INTERVAL_SECONDS=1.5

AUTH_ENABLED=true
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD_HASH='replace-with-generate-auth-secrets-output'
AUTH_SESSION_SECRET='replace-with-generate-auth-secrets-output'
AUTH_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=true
