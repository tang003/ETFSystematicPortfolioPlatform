APP_NAME=ETF Systematic Portfolio Platform
APP_ENV=local
API_PREFIX=/api
APP_ALLOWED_HOSTS=localhost,127.0.0.1
TRUST_PROXY_HEADERS=false

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=quant_etf
POSTGRES_USER=quant_etf
POSTGRES_PASSWORD=quant_etf_password

REDIS_HOST=redis
REDIS_PORT=6379

LOG_LEVEL=INFO

TUSHARE_TOKEN=
TUSHARE_REQUEST_INTERVAL_SECONDS=1.5

AUTH_ENABLED=false
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD_HASH=
AUTH_SESSION_SECRET=
AUTH_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=false
